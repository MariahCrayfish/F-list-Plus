{
  "name": "F-list+",
  "version": "1.0.2",
  "description": "Application to enhance the F-list user experience.",
  "manifest_version": 3,
  "author": "Mariah Crayfish",
  "host_permissions": ["*://*.f-list.net/*"],

  "content_scripts": [
    {
      "matches": ["https://www.f-list.net/character_edit.php*"],
      "js": ["upload.js", "customKinksSetup.js"]
    },
    {
      "matches": ["https://www.f-list.net/experimental/subfetish.php*"],
      "js": ["kinkAutomationSetUp.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "resize.js",
        "uploadGallery.js",
        "kinkAutomation.js",
        "customKinks.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_title": "Click Me",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "flistplus@mari2ahcrayfish.com"
    }
  }
}
